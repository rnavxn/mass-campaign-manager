# ====== POSTGRES CONFIG ======
# PostgreSQL config
POSTGRES_HOST=host_name
POSTGRES_PORT=5432
POSTGRES_DB=database_name
POSTGRES_USER=user_name
POSTGRES_PASSWORD=user_password

# MCM's own base URL — used to build webhook callback URL sent to DJP
# In Docker Compose, MCM is reachable by its service name
APP_SELF_BASE_URL=http://host.docker.internal:8081
 
# DJP producer URL — running in its own compose stack on host network
# host.docker.internal resolves to host machine from inside Docker
JOB_PROCESSOR_URL=http://host.docker.internal:8080